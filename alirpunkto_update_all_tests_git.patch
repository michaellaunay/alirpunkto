+    dummy_request.session["user"] = json.dumps({"name": "Alice"})
+    dummy_request.session[SSO_REFRESH] = "refresh-token"
+    dummy_request.session[SSO_EXPIRES_AT] = (datetime.now() + timedelta(minutes=5)).isoformat()
