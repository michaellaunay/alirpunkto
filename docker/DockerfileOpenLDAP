FROM ubuntu:24.04

LABEL maintainer="michaellaunay+alirpunkto@logikascium.com" \
      description="OpenLDAP server for AlirPunkto"

# Install OpenLDAP server and client utilities.
# - ldapvi and vim are excluded: not needed in a production image.
#   Use a debug build or `docker exec` with a separate tooling image instead.
# - schema2ldif is kept because start_ldap.sh may rely on it at runtime.


# Avoid interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Update package lists and install OpenLDAP server, client utilities and ldapvi
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        slapd \
        debconf-utils \
        ldap-utils \
        ldapvi \
        ca-certificates \
        ssl-cert \
        vim \
        schema2ldif \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

# Create directory for startup scripts
RUN mkdir -p /docker-entrypoint-initdb.d

# Create volume for LDAP configuration
VOLUME ["/etc/ldap", "/var/lib/ldap", "/schema"]

# Create startup script to initialize LDAP if needed
COPY ./initials_users.ldif /initials_users.ldif
COPY ./start_ldap.sh /
RUN chmod +x /start_ldap.sh

# Expose LDAP and LDAPS ports
EXPOSE 389 636

# Set the entrypoint to our custom start script
ENTRYPOINT ["/start_ldap.sh"]
# Default command - keep the container running
CMD ["slapd", "-h", "ldap:/// ldapi:/// ldaps:///", "-g", "openldap", "-u", "openldap", "-d", "256"]
