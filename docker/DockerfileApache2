FROM ubuntu:24.04

# Avoid interactive apt prompts during image build.
ENV DEBIAN_FRONTEND=noninteractive

# Install Apache, Certbot, and the small runtime needed to render the vhost template.
RUN apt-get update && apt-get install -y --no-install-recommends \
    apache2 \
    certbot \
    gettext-base \
    python3-certbot-apache \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Enable the Apache modules required for TLS termination and reverse proxying.
RUN a2enmod ssl rewrite proxy proxy_http headers remoteip

# Copy the generic site template used by the container entrypoint.
# The client-specific file `alirpunkto.cosmopolitical.coop.conf` is kept in the
# repository as a reference and is not enabled by default in this generic image.
COPY etc/apache2/sites-available/alirpunkto.conf.template /templates/alirpunkto.conf.template
COPY start_apache2.sh /usr/local/bin/start_apache2.sh

# Make the startup script executable and disable the default site.
RUN chmod +x /usr/local/bin/start_apache2.sh \
    && a2dissite 000-default.conf

# Expose HTTP and HTTPS.
EXPOSE 80 443

# Persist Let's Encrypt material and Apache logs.
VOLUME ["/etc/letsencrypt", "/var/lib/letsencrypt", "/var/log/apache2"]

# Start Apache through the custom entrypoint.
ENTRYPOINT ["/usr/local/bin/start_apache2.sh"]
