FROM ubuntu:24.04

# Avoid interactive apt prompts and keep Python logs unbuffered in containers.
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# Optional build-time switch to include extra debugging tools.
ARG BUILD_WITH_DEBUG=0
ENV BUILD_WITH_DEBUG=${BUILD_WITH_DEBUG}
ENV APP_HOME=/home/alirpunkto/app
ENV VENV_DIR=/home/alirpunkto/venv

# Install Python and the native libraries required by the application dependencies.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    libjpeg-dev \
    libldap2-dev \
    libsasl2-dev \
    libssl-dev \
    libxml2-dev \
    libxslt1-dev \
    libz-dev \
    libfreetype6-dev \
    libtiff-dev \
    && if [ "$BUILD_WITH_DEBUG" = "1" ]; then \
        apt-get install -y --no-install-recommends vim dnsutils iputils-ping net-tools telnet; \
    fi \
    && rm -rf /var/lib/apt/lists/*

# Create the application user and the virtual environment at build time.
RUN groupadd -g 1001 alirpunkto \
    && useradd -m -u 1001 -g 1001 -s /bin/bash alirpunkto \
    && python3 -m venv "${VENV_DIR}"

# The application source tree is copied into the image so runtime startup stays deterministic.
WORKDIR ${APP_HOME}

COPY . ${APP_HOME}
COPY docker/start_pyramid.sh /usr/local/bin/start_pyramid.sh

# Install the application into the virtualenv and prepare writable runtime directories.
RUN "${VENV_DIR}/bin/pip" install --no-cache-dir --upgrade pip setuptools wheel \
    && "${VENV_DIR}/bin/pip" install --no-cache-dir -e . \
    && chmod +x /usr/local/bin/start_pyramid.sh \
    && mkdir -p ${APP_HOME}/var/log ${APP_HOME}/var/datas ${APP_HOME}/var/filestorage ${APP_HOME}/var/sessions \
    && chown -R alirpunkto:alirpunkto /home/alirpunkto /usr/local/bin/start_pyramid.sh

# Persist application state and uploaded/generated files.
VOLUME ["/home/alirpunkto/app/var"]

# Run the app as the dedicated non-root user.
USER alirpunkto

# Expose the Waitress port used by `production.ini`.
EXPOSE 6543

# Start Pyramid through the custom entrypoint.
ENTRYPOINT ["/usr/local/bin/start_pyramid.sh"]

# Default to the production configuration file.
CMD ["production.ini"]
