FROM ubuntu:24.04

# Avoid interactive apt prompts during image build.
ENV DEBIAN_FRONTEND=noninteractive

# Install Postfix, OpenDKIM, and the minimal diagnostic/runtime tools used by the entrypoint.
RUN apt-get update && apt-get install -y --no-install-recommends \
    postfix \
    opendkim \
    opendkim-tools \
    mailutils \
    iproute2 \
    postfix-policyd-spf-python \
    dnsutils \
    ca-certificates \
    procps \
 && rm -rf /var/lib/apt/lists/*
   
# Copy the base configuration files and the startup script.
COPY etc/postfix/main.cf /etc/postfix/main.cf
COPY etc/opendkim.conf /etc/opendkim.conf
COPY start_postfix.sh /usr/local/bin/start_postfix.sh

# Prepare runtime directories and mark the entrypoint executable.
RUN chmod +x /usr/local/bin/start_postfix.sh \
    && mkdir -p /etc/dkimkeys /run/opendkim /etc/opendkim

# Persist the mail queue and DKIM keys.
VOLUME ["/var/spool/postfix", "/etc/dkimkeys"]

# Expose SMTP.
EXPOSE 25

# Start Postfix through the custom entrypoint.
ENTRYPOINT ["/usr/local/bin/start_postfix.sh"]
